sılame=(Çoğulu: Sılâmât) Bölük, cemaat, topluluk, fırka.
silan=Sapına girmiş olan kılıç ve bıçak ucu.
sılat=-(Tekili: Sıla) Sılalar.<br>-Bahşişler, armağanlar, hediyeler.
silb =(Çoğulu: Silebe) Dişleri kütelmiş ve kuyruğu dökülmüş yaşlı deve.
sıle=Bir şâire, yazdığı medhiye karşılığı olarak verilen para.
silfed=-Ahmak kimse.<br>-Kurt.
silhem=Bir kimsenin cisminde değişiklik olması.
sîlî=Tokat, sille.
sili=Tokat. Şamar.
silif=Bacanak.
silis-ül-bevl=Devamlı idrar kaçırmak. İdrârını tutamamak.
silizen=Tokat vuran, şamar atan, döven.
silk=-Dizi, sıra.<br>-Yol, tarik.<br>-İplik, hayt.
silka=(Bak: SİLK)
silka'=Arkası üstüne yatmak.
sıll=-(Çoğulu: Aslâl) Bir nevi ot.<br>-Bir nevi yılan.
